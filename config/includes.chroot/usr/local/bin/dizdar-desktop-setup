#!/bin/bash
# Dizdar Linux Desktop Setup - Sadece tema ve duvar kagidi, panel'e DOKUNMA!

echo "=== Dizdar Linux Desktop Setup ==="

# Oturum acildiktan sonra biraz bekle
sleep 3

# 1. Turkce klavye
setxkbmap tr || true

# 2. Masaustu ikonlari ayarlari (USB/disket gizle, ev/cop goster)
xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-removable -s false --create -t bool || true
xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-device -s false --create -t bool || true
xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-filesystem -s false --create -t bool || true
xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-trash -s true --create -t bool || true
xfconf-query -c xfce4-desktop -p /desktop-icons/file-icons/show-home -s true --create -t bool || true

# 3. Thunar sidebar'dan cikarabilir suruculer gizle
xfconf-query -c thunar -p /side-pane-devices-show-removable -s false --create -t bool || true

# 4. Windows 11 Dark Temasi, Ikonlar, Pencere dugmeleri
xfconf-query -c xsettings -p /Net/ThemeName -s "Win11-dark" --create -t string || true
xfconf-query -c xsettings -p /Net/IconThemeName -s "Win11-dark" --create -t string || true
xfconf-query -c xfwm4 -p /general/theme -s "Win11-dark" --create -t string || true
xfconf-query -c xfwm4 -p /general/button_layout -s "O|HMC" --create -t string || true

# 5. Duvar kagidi
xfconf-query -c xfce4-desktop -p /backdrop/screen0/monitor0/workspace0/last-image -s "/usr/share/backgrounds/dizdar_wallpaper.jpg" --create -t string || true
xfconf-query -c xfce4-desktop -p /backdrop/screen0/monitorVirtual-1/workspace0/last-image -s "/usr/share/backgrounds/dizdar_wallpaper.jpg" --create -t string || true

echo "=== Desktop Setup Completed ==="
